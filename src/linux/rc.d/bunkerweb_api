#!/bin/sh

# PROVIDE: bunkerweb_api
# REQUIRE: LOGIN DAEMON NETWORKING
# KEYWORD: shutdown
#
# Add the following line to /etc/rc.conf to enable bunkerweb_api:
#
# bunkerweb_api_enable="YES"
#

. /etc/rc.subr

name="bunkerweb_api"
rcvar="${name}_enable"
desc="BunkerWeb API service"

load_rc_config $name

: ${bunkerweb_api_enable:="NO"}
: ${bunkerweb_api_user:="root"}
: ${bunkerweb_api_group:="nginx"}
: ${bunkerweb_api_pidfile:="/var/run/bunkerweb/api.pid"}
: ${bunkerweb_api_wrapper_pidfile:="/var/run/bunkerweb/api-wrapper.pid"}

pidfile="${bunkerweb_api_pidfile}"
start_cmd="${name}_start"
stop_cmd="${name}_stop"
reload_cmd="${name}_reload"
status_cmd="${name}_status"
extra_commands="reload"

bunkerweb_api_start()
{
    echo "Starting ${name}."
    mkdir -p /var/run/bunkerweb
    /usr/sbin/daemon -f -p "${bunkerweb_api_wrapper_pidfile}" /usr/local/bin/bash /usr/share/bunkerweb/scripts/bunkerweb-api.sh start
}

bunkerweb_api_stop()
{
    if [ -f "${pidfile}" ]; then
        echo "Stopping ${name}."
        /usr/local/bin/bash /usr/share/bunkerweb/scripts/bunkerweb-api.sh stop
    else
        echo "${name} is not running."
    fi
    if [ -f "${bunkerweb_api_wrapper_pidfile}" ]; then
        wrapper_pid=$(cat "${bunkerweb_api_wrapper_pidfile}" 2>/dev/null)
        [ -n "${wrapper_pid}" ] && kill "${wrapper_pid}" 2>/dev/null || true
        rm -f "${bunkerweb_api_wrapper_pidfile}"
    fi
}

bunkerweb_api_reload()
{
    echo "Reloading ${name}."
    /usr/local/bin/bash /usr/share/bunkerweb/scripts/bunkerweb-api.sh reload
}

bunkerweb_api_status()
{
    if [ -f "${pidfile}" ]; then
        pid=$(cat "${pidfile}")
        if kill -0 "${pid}" 2>/dev/null; then
            echo "${name} is running as pid ${pid}."
            return 0
        fi
    fi
    echo "${name} is not running."
    return 1
}

run_rc_command "$1"
