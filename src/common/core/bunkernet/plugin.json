{
  "id": "bunkernet",
  "name": "BunkerNet",
  "description": "Share threat data with other BunkerWeb instances via BunkerNet.",
  "version": "1.0",
  "stream": "yes",
  "settings": {
    "USE_BUNKERNET": {
      "context": "multisite",
      "default": "yes",
      "help": "Activate BunkerNet feature.",
      "id": "use-bunkernet",
      "label": "Activate BunkerNet",
      "regex": "^(yes|no)$",
      "type": "check"
    },
    "BUNKERNET_SERVER": {
      "context": "global",
      "default": "https://api.bunkerweb.io",
      "help": "Address of the BunkerNet API.",
      "id": "bunkernet-server",
      "label": "BunkerNet server",
      "regex": "^https?:\\/\\/[\\-\\w@:%.+~#=]+[\\-\\w\\(\\)!@:%+.~#?&\\/=$]*$",
      "type": "text"
    },
    "USE_BUNKERNET_STATS": {
      "context": "global",
      "default": "yes",
      "help": "Persist BunkerNet effectiveness statistics (contribution, blocklist size, connectivity) to the database.",
      "id": "use-bunkernet-stats",
      "label": "BunkerNet effectiveness stats",
      "regex": "^(yes|no)$",
      "type": "check"
    },
    "BUNKERNET_STATS_RETENTION_DAYS": {
      "context": "global",
      "default": "30",
      "help": "Maximum age (in days) of persisted BunkerNet effectiveness statistics.",
      "id": "bunkernet-stats-retention-days",
      "label": "BunkerNet stats retention (days)",
      "regex": "^\\d+$",
      "type": "number"
    }
  },
  "jobs": [
    {
      "name": "bunkernet-register",
      "file": "bunkernet-register.py",
      "every": "hour",
      "reload": true
    },
    {
      "name": "bunkernet-data",
      "file": "bunkernet-data.py",
      "every": "day",
      "reload": true
    },
    {
      "name": "bunkernet-send",
      "file": "bunkernet-send.py",
      "every": "hour",
      "reload": true
    },
    {
      "name": "bunkernet-stats",
      "file": "bunkernet-stats.py",
      "every": "hour",
      "reload": false,
      "async": true
    },
    {
      "name": "bunkernet-cleanup-stats",
      "file": "bunkernet-cleanup-stats.py",
      "every": "day",
      "reload": false,
      "async": true
    }
  ],
  "extensions": {
    "api": {
      "module": "api/router.py",
      "prefix": "/bunkernet"
    },
    "db": {
      "models": "db/models.py",
      "methods": "db/methods.py",
      "table_prefix": "bw_bunkernet_"
    }
  }
}
